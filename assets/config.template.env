# prompt-rail model config — copy to <workdir>/config.env and edit.
#
# One place to declare BOTH models: the runner (runs the prompt under test)
# and the judge (scores output against a rubric). runner.sh and judge.sh
# source this file, so you never edit those scripts to switch providers.
#
#   set -a; . ./config.env; set +a    # what the scripts do internally
#
# SECURITY: this file stores only the *name* of the env var that holds each
# API key — never the key itself. That keeps config.env safe to commit and
# share. Export the actual key in your shell:  export XAI_API_KEY="sk-..."

# ─────────────────────────────────────────────────────────────────────────
# RUNNER — the model that runs the prompt you're optimizing.
# Use temperature 0 for repeatable scores (see references/iteration-loop.md).
# ─────────────────────────────────────────────────────────────────────────
# provider: openai_compatible | claude_cli
RUNNER_PROVIDER=openai_compatible
RUNNER_BASE=https://api.x.ai/v1          # OpenAI-compatible base URL (no trailing /chat/completions)
RUNNER_MODEL=grok-2-latest
RUNNER_API_KEY_ENV=XAI_API_KEY           # name of the env var holding the key
RUNNER_TEMPERATURE=0

# ─────────────────────────────────────────────────────────────────────────
# JUDGE — the model that scores output (LLM-as-judge). Optional: if you score
# on deterministic asserts alone, delete the judge block from suite.yaml and
# these are ignored. Judge with a STRONG model even when testing a weak one —
# the judge's job is discrimination, not speed.
# ─────────────────────────────────────────────────────────────────────────
# provider: claude_cli | openai_compatible
JUDGE_PROVIDER=claude_cli
JUDGE_MODEL=                             # blank = provider default (e.g. claude CLI's default)
JUDGE_BASE=                              # only needed for openai_compatible judge
JUDGE_API_KEY_ENV=ANTHROPIC_API_KEY      # only needed for openai_compatible judge
JUDGE_TEMPERATURE=0
